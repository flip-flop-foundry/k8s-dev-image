# Renovate keeps these values up-to-date automatically.
# The `# renovate:` comments tell it which upstream GitHub release stream to
# track. Do not remove them.

# renovate: datasource=github-releases depName=helm/helm
export HELM_VERSION=3.21.3

# renovate: datasource=github-releases depName=mikefarah/yq
export YQ_VERSION=v4.53.3

# renovate: datasource=github-releases depName=cilium/cilium-cli
export CILIUM_CLI_VERSION=0.19.6

# renovate: datasource=github-releases depName=derailed/k9s
export K9S_VERSION=v0.51.0

# renovate: datasource=github-releases depName=argoproj/argo-cd
export ARGOCD_VERSION=3.4.5

# renovate: datasource=github-releases depName=cert-manager/cmctl
export CMCTL_VERSION=v2.5.0

# renovate: datasource=github-releases depName=kubevirt/kubevirt
export VIRTCTL_VERSION=v1.8.4

# renovate: datasource=github-releases depName=github/copilot-cli
export COPILOT_CLI_VERSION=1.0.75

# claude-code uses the special "latest" pointer, so we skip Renovate for it.
export CLAUDE_VERSION=latest

# renovate: datasource=github-releases depName=cloudnative-pg/cloudnative-pg
export CNPG_VERSION=v1.30.0

# renovate: datasource=github-releases depName=kubernetes/kubernetes
export KUBECTL_VERSION=1.36.3

# renovate: datasource=github-releases depName=siderolabs/talos
export TALOSCTL_VERSION=1.13.7